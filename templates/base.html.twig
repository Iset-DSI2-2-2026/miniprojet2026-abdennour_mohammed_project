<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}BookShelf{% endblock %} | AdminLTE</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>📚</text></svg>">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fontsource/source-sans-3@5.0.12/index.css" crossorigin="anonymous" media="print" onload="this.media='all'">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/overlayscrollbars@2.11.0/styles/overlayscrollbars.min.css" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css" crossorigin="anonymous">
    <link rel="stylesheet" href="{{ asset('adminlte/css/adminlte.css') }}">
    {% block stylesheets %}{% endblock %}
    {% block javascripts %}
        {% block importmap %}{{ importmap('app') }}{% endblock %}
    {% endblock %}
</head>
<body class="layout-fixed sidebar-expand-lg bg-body-tertiary">
<div class="app-wrapper">
    <nav class="app-header navbar navbar-expand bg-body">
        <div class="container-fluid">
            <ul class="navbar-nav">
                <li class="nav-item">
                    <a class="nav-link" data-lte-toggle="sidebar" href="#" role="button"><i class="bi bi-list"></i></a>
                </li>
                <li class="nav-item d-none d-md-block"><a href="{{ path('app_home') }}" class="nav-link">Accueil</a></li>
                <li class="nav-item d-none d-md-block"><a href="{{ path('app_livre_index') }}" class="nav-link">Livres</a></li>
                <li class="nav-item d-none d-md-block"><a href="{{ path('app_ma_liste') }}" class="nav-link">Ma liste</a></li>
            </ul>
            <ul class="navbar-nav ms-auto">
                <li class="nav-item">
                    <a class="nav-link" href="{{ path('app_ma_liste') }}">
                        <i class="bi bi-bookmark-heart"></i>
                        <span class="badge text-bg-secondary">{{ ma_liste_count() }}</span>
                    </a>
                </li>
                {% if app.user %}
                    <li class="nav-item d-flex align-items-center me-2">
                        <span class="navbar-text small">{{ app.user.pseudo }}</span>
                    </li>
                    <li class="nav-item"><a class="nav-link" href="{{ path('app_logout') }}">Déconnexion</a></li>
                {% else %}
                    <li class="nav-item"><a class="nav-link" href="{{ path('app_login') }}">Connexion</a></li>
                    <li class="nav-item"><a class="nav-link" href="{{ path('app_register') }}">Inscription</a></li>
                {% endif %}
            </ul>
        </div>
    </nav>

    <aside class="app-sidebar bg-body-secondary shadow" data-bs-theme="dark">
        <div class="sidebar-brand">
            <a href="{{ path('app_home') }}" class="brand-link">
                <span class="brand-text fw-light">BookShelf</span>
            </a>
        </div>
        <div class="sidebar-wrapper">
            <nav class="mt-2">
                <ul class="nav sidebar-menu flex-column" data-lte-toggle="treeview" role="navigation" data-accordion="false">
                    <li class="nav-item"><a href="{{ path('app_home') }}" class="nav-link"><i class="nav-icon bi bi-house"></i><p>Accueil</p></a></li>
                    <li class="nav-item"><a href="{{ path('app_livre_index') }}" class="nav-link"><i class="nav-icon bi bi-book"></i><p>Livres</p></a></li>
                    <li class="nav-item"><a href="{{ path('app_ma_liste') }}" class="nav-link"><i class="nav-icon bi bi-journal-text"></i><p>Ma liste de lecture</p></a></li>
                    {% if is_granted('ROLE_ADMIN') %}
                        <li class="nav-header text-uppercase small mt-2">Administration</li>
                        <li class="nav-item"><a href="{{ path('app_auteur_index') }}" class="nav-link"><i class="nav-icon bi bi-person"></i><p>Auteurs</p></a></li>
                        <li class="nav-item"><a href="{{ path('app_genre_index') }}" class="nav-link"><i class="nav-icon bi bi-tags"></i><p>Genres</p></a></li>
                        <li class="nav-item"><a href="{{ path('app_tag_index') }}" class="nav-link"><i class="nav-icon bi bi-bookmark"></i><p>Tags</p></a></li>
                    {% endif %}
                    {% if is_granted('ROLE_BIBLIOTHECAIRE') %}
                        <li class="nav-item"><a href="{{ path('app_livre_nouveau') }}" class="nav-link"><i class="nav-icon bi bi-plus-circle"></i><p>Nouveau livre</p></a></li>
                    {% endif %}
                </ul>
            </nav>
        </div>
    </aside>

    <main class="app-main">
        <div class="app-content-header">
            <div class="container-fluid">
                <div class="row mb-2">
                    <div class="col-sm-6"><h3 class="mb-0">{% block page_title %}{% endblock %}</h3></div>
                </div>
            </div>
        </div>
        <div class="app-content">
            <div class="container-fluid">
                {% for label, messages in app.flashes %}
                    {% for message in messages %}
                        <div class="alert alert-{{ label == 'error' ? 'danger' : label }} alert-dismissible fade show" role="alert">
                            {{ message }}
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    {% endfor %}
                {% endfor %}
                {% block body %}{% endblock %}
            </div>
        </div>
    </main>

    <footer class="app-footer">
        <div class="float-end d-none d-sm-inline">Symfony 7 · BookShelf</div>
        <strong><a href="https://adminlte.io" class="text-decoration-none" target="_blank" rel="noopener">AdminLTE</a></strong>
    </footer>
</div>

<script src="https://cdn.jsdelivr.net/npm/overlayscrollbars@2.11.0/browser/overlayscrollbars.browser.es6.min.js" crossorigin="anonymous"></script>
<script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.8/dist/umd/popper.min.js" crossorigin="anonymous"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
<script src="{{ asset('adminlte/js/adminlte.js') }}"></script>
<script>
    document.addEventListener('DOMContentLoaded', function () {
        const sidebarWrapper = document.querySelector('.sidebar-wrapper');
        const isMobile = window.innerWidth <= 992;
        if (sidebarWrapper && typeof OverlayScrollbarsGlobal !== 'undefined' && !isMobile) {
            OverlayScrollbarsGlobal.OverlayScrollbars(sidebarWrapper, {
                scrollbars: {theme: 'os-theme-light', autoHide: 'leave', clickScroll: true},
            });
        }
    });
</script>
{% block body_scripts %}{% endblock %}
</body>
</html>
