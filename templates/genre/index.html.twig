{% extends 'base.html.twig' %}

{% block title %}Genres{% endblock %}
{% block page_title %}Genres{% endblock %}

{% block body %}
    <p><a href="{{ path('app_genre_nouveau') }}" class="btn btn-primary">Nouveau genre</a></p>
    <div class="card">
        <div class="card-body table-responsive p-0">
            <table class="table table-striped mb-0">
                <thead>
                <tr><th>Nom</th><th>Couleur</th><th>Description</th></tr>
                </thead>
                <tbody>
                {% for genre in genres %}
                    <tr>
                        <td>{{ genre.nom }}</td>
                        <td><span class="badge" style="background-color: {{ genre.couleur }}; color:#fff;">{{ genre.couleur }}</span></td>
                        <td>{{ genre.description }}</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
